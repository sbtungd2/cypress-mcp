{
  "name": "@tms-cymcp/cypress-mcp",
  "version": "0.1.0",
  "description": "MCP server plugin for Cypress — let AI agents control your browser for testing",
  "keywords": ["cypress", "mcp", "model-context-protocol", "ai", "testing", "automation", "browser"],
  "license": "MIT",
  "author": "sbtungd2",
  "repository": {
    "type": "git",
    "url": "https://github.com/sbtungd2/cypress-mcp.git"
  },
  "homepage": "https://github.com/sbtungd2/cypress-mcp#readme",
  "bugs": {
    "url": "https://github.com/sbtungd2/cypress-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "require": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./plugin": { "import": "./dist/plugin.js", "require": "./dist/plugin.js", "types": "./dist/plugin.d.ts" },
    "./support": { "import": "./dist/support.js", "require": "./dist/support.js", "types": "./dist/support.d.ts" }
  },
  "bin": { "cypress-mcp": "./dist/cli.js" },
  "files": ["dist/", "README.md", "LICENSE", "SECURITY.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "echo \"Tests placeholder\"",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "peerDependencies": {
    "cypress": ">=12.0.0"
  },
  "devDependencies": {
    "cypress": "^13.15.0",
    "typescript": "^5.6.0",
    "@types/ws": "^8.5.0",
    "@types/node": "^22.0.0"
  }
}
